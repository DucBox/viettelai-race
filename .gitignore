# Local secrets
serve/.env

# Local Claude Code tool state (per-machine, not project source)
.claude/

# Model weights — never commit; place manually, see serve/models/README.md
serve/models/*/
!serve/models/README.md

# Vendored AIPerf clone (external dependency, not this project's source)
/aiperf/

# venvs
.venv/
bench/.venv/
bench/.venv-lmeval/

# Generated from the .yaml.template files in this dir (each has an absolute,
# machine-specific path baked in) — regenerated every run by scripts/12 and
# scripts/13. Only the .template files are source; this covers any task name,
# present or future, without needing a new entry per task.
bench/lmeval_tasks/gpqa_diamond_local/*.yaml
!bench/lmeval_tasks/gpqa_diamond_local/*.yaml.template

# AIPerf outputs
artifacts/
**/artifacts/
bench/bench_results/

# Original competition trace (provided by organizers) — not tracked in git.
# Only the converted AIPerf replay input (data/*.aiperf.jsonl) is committed,
# since that's the file the bench actually fires requests from.
data/trace-round1.jsonl
data/trace-round1.short.jsonl

# Raw GPQA-diamond dump — redundant with the tracked data/GPQA/ copy; local only
gpqa_diamond.csv

# serve_up.sh native-mode runtime state
serve/.vllm.pid
serve/vllm.log

# Submission compose files (reference the pushed Docker Hub image tag) — local only
/submit/

# Local bench outputs (traces, replay json, profiler dumps) — regenerated per GPU run
/output/

# misc
.DS_Store
__pycache__/
*.pyc
