# ── Copy this file to .env on the GPU box and adjust ────────────────────────
#   cp .env.example .env

# vLLM image to run. Defaults to the public Docker Hub baseline image; on the
# internal server, point this at the image already sitting in your registry:
#   IMAGE=registry.internal.example.com/team/vllm-openai:v0.22.1
IMAGE=vllm/vllm-openai:v0.22.1

# Which physical GPU (by index, per `nvidia-smi` / scripts/00_list_gpus.sh) to
# dedicate to this container. On a 4-card host, pick exactly ONE idle card —
# docker-compose.yml pins the container to it via device_ids, the other 3
# cards are left alone for other jobs.
GPU_ID=0

# Local model directory on the HOST, relative to serve/ (or an absolute path).
# Must already contain config.json + tokenizer files + safetensors — see
# serve/models/README.md for the expected layout. This repo does NOT download
# models; scripts/01_check_model.sh verifies the directory before you serve.
MODEL_DIR=./models/qwen3.5-2b

# Where that directory is mounted INSIDE the container. vLLM is pointed at this
# path, not a HuggingFace repo id — no network pull, matches the competition's
# "no runtime model pull" rule.
MODEL_PATH=/models/qwen3.5-2b

# ── vLLM serving knobs ───────────────────────────────────────────────────────
# TWO different goals here — pick which one you're doing:
#
# (A) Quick flow-verify on any GPU (defaults below): MAX_MODEL_LEN=32768,
#     GPU_MEM_UTIL=0.90. Just proves serve→infer→metrics works. Not
#     competition-representative.
#
# (B) Competition-accurate test: the BTC baseline is max-model-len=262144,
#     gpu-memory-utilization=0.95 on an 18 GiB MIG H200 slice — i.e. an
#     ABSOLUTE memory budget of 0.95 × 18 = 17.1 GiB. If you're testing on a
#     card with a different total VRAM (e.g. an L40S with 46 GiB), do NOT copy
#     0.95 verbatim — that targets 0.95 × 46 ≈ 43.7 GiB, nothing like the real
#     constraint. Instead scale GPU_MEM_UTIL to reproduce the SAME absolute
#     budget on your card:
#
#       GPU_MEM_UTIL = (0.95 × 18) / <your card's total VRAM in GiB>
#
#     Example for a 46 GiB L40S: (0.95 × 18) / 46 ≈ 0.37
#
#     This is also the real experiment for whether max-model-len=262144 is
#     even safe on the 18 GiB slice (vLLM's own memory profiling logs will
#     show whether KV cache still fits, or whether it should be lowered —
#     see docs/qwen35-architecture.html §5 Property B).
MAX_MODEL_LEN=32768

# Fraction of GPU memory vLLM may use. See the (A) vs (B) note above — for a
# competition-accurate test, compute this from your card's total VRAM instead
# of using this default.
GPU_MEM_UTIL=0.90

# Max concurrent sequences. Trace has 20 parallel sessions → 20 is the natural
# number to test the real burst; bump to 32 for margin.
MAX_NUM_SEQS=32

# Served model name that clients (AIPerf) will target. Keep it stable.
SERVED_MODEL_NAME=qwen3.5-2b

# ── Extra vLLM flags (the sweep knob) ────────────────────────────────────────
# Anything here is appended VERBATIM to `vllm serve`, so you can try any flag
# (including value-less ones) WITHOUT editing docker-compose.yml or serve_up.sh.
# Space-separated, written exactly as on the CLI. Leave empty for none.
# Applies in all three launch paths (native / docker compose / docker run).
# Examples for the optimization sweep (see docs/vllm-optimization-guide.md):
#   EXTRA_VLLM_ARGS="--enable-chunked-prefill --max-num-batched-tokens 16384"
#   EXTRA_VLLM_ARGS="--mamba-cache-mode all"           # A/B vs default 'align'
#   EXTRA_VLLM_ARGS="--quantization compressed-tensors --kv-cache-dtype fp8"
EXTRA_VLLM_ARGS=
