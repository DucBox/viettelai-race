# ── Copy this file to .env on the GPU box and adjust ────────────────────────
#   cp .env.example .env

# vLLM image to run. Defaults to the public Docker Hub baseline image; on the
# internal server, point this at the image already sitting in your registry:
#   IMAGE=registry.internal.example.com/team/vllm-openai:v0.22.1
IMAGE=vllm/vllm-openai:v0.22.1

# Which physical GPU (by index, per `nvidia-smi` / scripts/00_list_gpus.sh) to
# dedicate to this container. On a 4-card host, pick exactly ONE idle card —
# docker-compose.yml pins the container to it via device_ids, the other 3
# cards are left alone for other jobs.
GPU_ID=0

# Local model directory on the HOST, relative to serve/ (or an absolute path).
# Must already contain config.json + tokenizer files + safetensors — see
# serve/models/README.md for the expected layout. This repo does NOT download
# models; scripts/01_check_model.sh verifies the directory before you serve.
MODEL_DIR=./models/qwen3.5-2b

# Where that directory is mounted INSIDE the container. vLLM is pointed at this
# path, not a HuggingFace repo id — no network pull, matches the competition's
# "no runtime model pull" rule.
MODEL_PATH=/models/qwen3.5-2b

# ── vLLM serving knobs (TEST profile — small GPU friendly) ──────────────────
# The BTC baseline uses max-model-len=262144 which only fits on H200-class cards.
# For the verify-the-flow test on a small GPU (RTX 3060 / L4 / A10), keep it low.
# The trace needs ~25k prompt + 200 output, so 32768 is the realistic minimum
# you'd use for a competition-like test.
MAX_MODEL_LEN=32768

# Fraction of GPU memory vLLM may use. Baseline is 0.95; leave headroom on a
# shared dev box.
GPU_MEM_UTIL=0.90

# Max concurrent sequences. Trace has 20 parallel sessions → 20 is the natural
# number to test the real burst; bump to 32 for margin.
MAX_NUM_SEQS=32

# Served model name that clients (AIPerf) will target. Keep it stable.
SERVED_MODEL_NAME=qwen3.5-2b
